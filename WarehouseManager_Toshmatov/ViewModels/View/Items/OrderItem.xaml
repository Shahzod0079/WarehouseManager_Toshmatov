<UserControl x:Class="WarehouseManager_Toshmatov.Views.Items.OrderItem"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WarehouseManager_Toshmatov.Views.Items"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>
        <Style TargetType="Button" x:Key="Update">
            <Setter Property="Background" Value="#FF2DD61B" />
            <Setter Property="BorderBrush" Value="#FF2DD61B" />
            <Setter Property="Foreground" Value="White" />
        </Style>
        <Style TargetType="Button" x:Key="Delete">
            <Setter Property="Background" Value="#FFD62F1B" />
            <Setter Property="BorderBrush" Value="#FFD62F1B" />
            <Setter Property="Foreground" Value="White" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="10" Background="White">
        <Grid.Effect>
            <DropShadowEffect Opacity="0.1"/>
        </Grid.Effect>
        <Image Width="40" Height="40" Margin="10" VerticalAlignment="Top" HorizontalAlignment="Left" Source="/Image/ic_order.png"/>

        <Grid Margin="60,0,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="270"/>
            </Grid.ColumnDefinitions>

            <Grid Margin="10" Height="60" VerticalAlignment="Top" Background="White">
                <Grid.Effect>
                    <DropShadowEffect Opacity="0.1"/>
                </Grid.Effect>
                <Label Content="Наименование:" VerticalAlignment="Top" Margin="10,0,10,0"/>
                <TextBox Text="{Binding ProductName}" IsEnabled="{Binding IsEnable}" 
                         VerticalContentAlignment="Center" Margin="10,25,10,0" 
                         VerticalAlignment="Top" Height="25"/>
            </Grid>

            <Grid Margin="10,80,10,0" Height="60" VerticalAlignment="Top" Background="White">
                <Grid.Effect>
                    <DropShadowEffect Opacity="0.1"/>
                </Grid.Effect>
                <Label Content="Поставщик:" VerticalAlignment="Top" Margin="10,0,10,0"/>
                <ComboBox ItemsSource="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Page}}, 
                          Path=DataContext.Suppliers}"  DisplayMemberPath="Name"   SelectedValue="{Binding SupplierId}"  
                          SelectedValuePath="Id" IsEnabled="{Binding IsEnable}"   Height="25" Margin="10,25,10,0"/>
            </Grid>

            <Grid Margin="10,150,10,0" Height="60" VerticalAlignment="Top" Background="White">
                <Grid.Effect>
                    <DropShadowEffect Opacity="0.1"/>
                </Grid.Effect>
                <Label Content="Количество:" VerticalAlignment="Top" Margin="10,0,10,0"/>
                <TextBox Text="{Binding Quantity}" IsEnabled="{Binding IsEnable}" 
                         VerticalContentAlignment="Center" Margin="10,25,10,0"  VerticalAlignment="Top" Height="25"/>
            </Grid>

            <Grid Margin="10,220,10,0" Height="60" VerticalAlignment="Top" Background="White">
                <Grid.Effect>
                    <DropShadowEffect Opacity="0.1"/>
                </Grid.Effect>
                <Label Content="Цена:" VerticalAlignment="Top" Margin="10,0,10,0"/>
                <TextBox Text="{Binding Price}" IsEnabled="{Binding IsEnable}" 
                         VerticalContentAlignment="Center" Margin="10,25,10,0"  VerticalAlignment="Top" Height="25"/>
            </Grid>

            <Grid Margin="10,10,10,0" Height="60" VerticalAlignment="Top" Background="White" Grid.Column="1">
                <Grid.Effect>
                    <DropShadowEffect Opacity="0.1"/>
                </Grid.Effect>
                <Label Content="Дата заказа:" VerticalAlignment="Top" Margin="10,0,10,0"/>
                <DatePicker SelectedDate="{Binding OrderDate}"  IsEnabled="{Binding IsEnable}"   VerticalContentAlignment="Center" 
                            Margin="10,25,10,0"   VerticalAlignment="Top" Height="25"/>
            </Grid>

            <Grid Margin="10,80,10,0" Height="60" VerticalAlignment="Top" Background="White" Grid.Column="1">
                <Grid.Effect>
                    <DropShadowEffect Opacity="0.1"/>
                </Grid.Effect>
                <Label Content="Сумма:" VerticalAlignment="Top" Margin="10,0,10,0"/>
                <TextBox Text="{Binding TotalAmount, StringFormat={}{0:C}}"  IsEnabled="False" Background="#F5F5F5" VerticalContentAlignment="Center" 
                         Margin="10,25,10,0"  VerticalAlignment="Top"   Height="25"/>
            </Grid>

            <Button Style="{StaticResource Update}" Command="{Binding OnEdit}"  Content="{Binding IsEnableText}"  Height="25" Width="70"
                    VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,160,10,0"  Grid.Column="1">
                <Button.Effect>
                    <DropShadowEffect Opacity="0.5" BlurRadius="3" ShadowDepth="3"/>
                </Button.Effect>
            </Button>

            <Button Style="{StaticResource Update}"  IsEnabled="{Binding IsEnable}"  Content="{Binding StatusText}"  Command="{Binding OnToggleStatus}" 
                    Height="25" Width="70" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,160,85,10" Grid.Column="1">
                <Button.Effect>
                    <DropShadowEffect Opacity="0.5" BlurRadius="3" ShadowDepth="3"/>
                </Button.Effect>
            </Button>

            <Button Style="{StaticResource Delete}" IsEnabled="{Binding IsEnable}" Command="{Binding OnDelete}"   Content="Удалить"  
                    Height="25" Width="70" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,160,160,0" Grid.Column="1">
                <Button.Effect>
                    <DropShadowEffect Opacity="0.5" BlurRadius="3" ShadowDepth="3"/>
                </Button.Effect>
            </Button>
        </Grid>
    </Grid>
</UserControl>