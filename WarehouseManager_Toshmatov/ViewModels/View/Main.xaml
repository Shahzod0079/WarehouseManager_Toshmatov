<Page x:Class="WarehouseManager_Toshmatov.Views.Main"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:elements="clr-namespace:WarehouseManager_Toshmatov.Views.Items"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Main">

    <Page.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#FF4FC318"/>
            <Setter Property="BorderBrush" Value="#FF4FC318"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="10,5"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Информационная панель с общей суммой -->
        <Border Grid.Row="0" Background="#FFE8E8E8" Padding="10" Margin="5">
            <TextBlock Text="{Binding TotalOrdersSum}" 
                       FontSize="16" 
                       FontWeight="Bold"
                       HorizontalAlignment="Center"/>
        </Border>

        <!-- Панель фильтров -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="10" HorizontalAlignment="Center">
            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                     Width="250" Height="30" 
                     VerticalContentAlignment="Center" 
                     Margin="0,0,10,0"  
                     ToolTip="Поиск по названию продукта"/>

            <ComboBox ItemsSource="{Binding Suppliers}" 
                      DisplayMemberPath="Name"
                      SelectedItem="{Binding SelectedSupplier}"
                      Width="150" Height="30"
                      Margin="0,0,10,0"
                      ToolTip="Фильтр по поставщику"/>

            <Button Command="{Binding OnResetFilters}" 
                    Content="Сбросить" 
                    Width="80" Height="30"/>
        </StackPanel>

        <!-- Список заказов -->
        <ListView Grid.Row="2" 
                  ItemsSource="{Binding Orders}" 
                  HorizontalContentAlignment="Stretch" 
                  Margin="10,0,10,10">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <elements:OrderItem DataContext="{Binding}"/>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Кнопка добавления -->
        <Button Grid.Row="3" 
                Command="{Binding OnAddOrder}" 
                Content="Добавить заказ" 
                Height="35" Width="120" 
                VerticalAlignment="Bottom" 
                HorizontalAlignment="Right" 
                Margin="0,0,10,10">
            <Button.Effect>
                <DropShadowEffect Opacity="0.5" BlurRadius="3" ShadowDepth="3"/>
            </Button.Effect>
        </Button>
    </Grid>
</Page>